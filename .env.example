# Copy this file to `.env` and fill in the values you need.
# Loaded automatically at runtime via python-dotenv; no manual `export` required.

# HuggingFace access token (for gated models like Llama, SecAlign).
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# OpenAI API key (only needed if you run GPT models).
OPENAI_API_KEY=

# DeepSeek API key (only needed if you run DeepSeek models).
DEEPSEEK_API_KEY=
